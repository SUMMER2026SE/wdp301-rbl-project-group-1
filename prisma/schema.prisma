// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

//////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE

  @@map("attendance_status")
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED

  @@map("session_status")
}

//////////////////////////////////////////////////

enum RequestStatus {
  OPEN
  CLOSED
  CANCELLED

  @@map("request_status")
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED

  @@map("bid_status")
}

enum TutoringMode {
  ONLINE
  AT_HOME

  @@map("tutoring_mode")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED

  @@map("booking_status")
}

enum UserRole {
  ADMIN
  TUTOR
  STUDENT

  @@map("user_role")
}

enum Gender {
  MALE
  FEMALE
  OTHER

  @@map("gender")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED

  @@map("payment_status")
}

enum PaymentReferenceType {
  TUTOR_BOOKING

  @@map("payment_reference_type")
}

enum NotificationType {
  SYSTEM
  FORUM

  @@map("notification_type")
}

enum ReportStatus {
  PENDING
  RESOLVED
  REJECTED

  @@map("report_status")
}

enum TutorApplicationStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("tutor_application_status")
}

enum TagCategory {
  KNOWLEDGE
  SKILL
  TOOL
}

enum ResourceType {
  FILE
  VIDEO
  LINK
  DOCUMENT

  @@map("resource_type")
}

enum AuthProvider {
  LOCAL
  GOOGLE

  @@map("auth_provider")
}

enum ConversationType {
  DIRECT
  GROUP

  @@map("conversation_type")
}

enum ParticipantRole {
  MEMBER
  ADMIN

  @@map("participant_role")
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM

  @@map("message_type")
}

//////////////////////////////////////////////////
// USER SYSTEM
//////////////////////////////////////////////////

/// Consolidated User model — merges former Profile (1:1) and Student (1:1) fields.
/// Profile fields: nickname, avatarUrl, phone, dateOfBirth, gender, address
/// Student fields: school, learningGoal
/// Many-to-many: subjects, grades (formerly StudentSubject/StudentGrade)
model User {
  id       String   @id @default(cuid())
  email    String   @unique
  password String
  role     UserRole

  isActive    Boolean @default(true) @map("is_active")
  isVerified  Boolean @default(false) @map("is_verified")
  isFlag      Boolean @default(false) @map("is_flag")
  reportCount Int     @default(0) @map("report_count")

  createdAt DateTime @default(now()) @map("created_at")

  recommendation Json?

  // --- Profile fields (merged from Profile model) ---
  nickname    String?
  avatarUrl   String?   @map("avatar_url")
  phone       String?   @map("phone")
  dateOfBirth DateTime? @map("date_of_birth")
  gender      Gender?   @map("gender")
  address     String?   @map("address")

  // --- Student fields (merged from Student model) ---
  school       String?
  learningGoal String? @map("learning_goal")

  // --- Relations ---
  identities    UserIdentity[]
  refreshTokens RefreshToken[]

  tutor            Tutor?
  tutorApplication TutorApplication?

  // Student many-to-many (replaces StudentSubject/StudentGrade junction tables)
  subjects Subject[] @relation("StudentSubjects")
  grades   Grade[]   @relation("StudentGrades")

  // Student domain relations (formerly on Student model)
  bookings      Booking[]      @relation("StudentBookings")
  tutorRequests TutorRequest[]

  // General relations
  posts         Post[]
  comments      Comment[]
  notifications NotificationTarget[]
  reports       Report[]             @relation("Reporter")
  postLikes     PostLike[]
  resources     Resource[]
  payments      Payment[]

  conversations ConversationParticipant[]
  messages      Message[]

  sessionAttendances SessionAttendance[]
  availabilities     UserAvailability[]

  @@map("user")
}

model UserIdentity {
  id String @id @default(cuid())

  userId         String       @map("user_id")
  provider       AuthProvider
  providerUserId String       @map("provider_user_id")
  email          String?
  emailVerified  Boolean      @default(false) @map("email_verified")
  avatarUrl      String?      @map("avatar_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@index([provider, email])
  @@map("user_identity")
}

/// Tutor profile — kept as separate model due to domain-specific fields and many relations.
/// Many-to-many: subjects, grades (replaces TutorSubject/TutorGrade junction tables)
model Tutor {
  id   String @id @map("id")
  user User   @relation(fields: [id], references: [id])

  bio            String?
  specialization String?
  experience     Int?
  education      String?
  pricePerHour   Float?  @map("price_per_hour")
  rating         Float   @default(0)
  reviewCount    Int     @default(0) @map("review_count")
  studentCount   Int     @default(0) @map("student_count")

  // Implicit many-to-many (replaces TutorSubject/TutorGrade)
  subjects  Subject[]  @relation("TutorSubjects")
  grades    Grade[]    @relation("TutorGrades")
  bookings  Booking[]
  tutorBids TutorBid[]

  @@map("tutor")
}

model TutorApplication {
  id String @id @default(cuid())

  email  String  @unique
  userId String? @unique @map("user_id")

  bio            String?
  specialization String
  experience     Int?
  education      String?
  pricePerHour   Float?   @map("price_per_hour")
  avatarUrl      String?  @map("avatar_url")
  files          String[] @default([])

  status TutorApplicationStatus @default(PENDING)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Implicit many-to-many (replaces TutorApplicationSubject/TutorApplicationGrade)
  subjects Subject[] @relation("TutorApplicationSubjects")
  grades   Grade[]   @relation("TutorApplicationGrades")

  @@index([status])
  @@index([createdAt])
  @@map("tutor_application")
}

//////////////////////////////////////////////////
// AUTH
//////////////////////////////////////////////////

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  revoked   Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_token")
}

//////////////////////////////////////////////////
// CLASS SYSTEM
//////////////////////////////////////////////////

// ================= SUBJECT =================
model Subject {
  id String @id @default(cuid())

  name String // "Toán"
  slug String @unique // "toan"

  createdAt DateTime @default(now()) @map("created_at")

  // Implicit many-to-many back-references
  tutors            Tutor[]            @relation("TutorSubjects")
  students          User[]             @relation("StudentSubjects")
  tutorApplications TutorApplication[] @relation("TutorApplicationSubjects")

  bookings      Booking[]
  tutorRequests TutorRequest[]

  @@map("subject")
}

// ================= GRADE =================
model Grade {
  id String @id @default(cuid())

  name  String // "Lớp 11"
  slug  String @unique // "lop-11"
  order Int // để sort (10, 11, 12)

  createdAt DateTime @default(now()) @map("created_at")

  // Implicit many-to-many back-references
  tutors            Tutor[]            @relation("TutorGrades")
  students          User[]             @relation("StudentGrades")
  tutorApplications TutorApplication[] @relation("TutorApplicationGrades")

  @@map("grade")
}

// ================= TAG =================
model Tag {
  id String @id @default(cuid())

  name String // "Đạo hàm", "React"
  slug String @unique

  category TagCategory

  createdAt DateTime @default(now()) @map("created_at")

  @@map("tag")
}

//////////////////////////////////////////////////
// RESOURCE SYSTEM
//////////////////////////////////////////////////

model Resource {
  id     String       @id @default(cuid())
  userId String       @map("user_id")
  name   String
  url    String
  type   ResourceType
  size   Int? // Size in bytes

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deletedAt])
  @@map("resource")
}

//////////////////////////////////////////////////
// FORUM
//////////////////////////////////////////////////

model Post {
  id     String @id @default(cuid())
  userId String @map("user_id")

  title     String
  content   String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @map("updated_at")

  user       User           @relation(fields: [userId], references: [id])
  comments   Comment[]
  likes      PostLike[]
  categories PostCategory[]

  @@map("post")
}

model Comment {
  id     String @id @default(cuid())
  postId String @map("post_id")
  userId String @map("user_id")

  content   String
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@map("comment")
}

model PostLike {
  userId String @map("user_id")
  postId String @map("post_id")

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])

  @@id([userId, postId])
  @@map("post_like")
}

model Category {
  id   String @id @default(cuid())
  name String

  posts PostCategory[]

  @@map("category")
}

model PostCategory {
  postId     String @map("post_id")
  categoryId String @map("category_id")

  post     Post     @relation(fields: [postId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@id([postId, categoryId])
  @@map("post_category")
}

//////////////////////////////////////////////////
// CHAT SYSTEM
//////////////////////////////////////////////////

model Conversation {
  id        String           @id @default(cuid())
  type      ConversationType
  name      String?
  avatarUrl String?          @map("avatar_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversation")
}

model ConversationParticipant {
  conversationId String          @map("conversation_id")
  userId         String          @map("user_id")
  role           ParticipantRole @default(MEMBER)

  lastReadMessageId String? @map("last_read_message_id")

  joinedAt DateTime @default(now()) @map("joined_at")

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadMessage Message?     @relation("LastReadMessage", fields: [lastReadMessageId], references: [id], onDelete: SetNull)

  @@id([conversationId, userId])
  @@index([userId])
  @@map("conversation_participant")
}

model Message {
  id             String  @id @default(cuid())
  conversationId String  @map("conversation_id")
  senderId       String? @map("sender_id") // Nullable for SYSTEM messages

  content String
  type    MessageType @default(TEXT)
  fileUrl String?     @map("file_url")

  replyToId String? @map("reply_to_id")

  isDeleted Boolean @default(false) @map("is_deleted")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?        @relation(fields: [senderId], references: [id], onDelete: SetNull)
  replyTo      Message?     @relation("ReplyTo", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      Message[]    @relation("ReplyTo")

  readBy ConversationParticipant[] @relation("LastReadMessage")

  @@index([conversationId])
  @@index([senderId])
  @@map("message")
}

//////////////////////////////////////////////////
// NOTIFICATION
//////////////////////////////////////////////////

model Notification {
  id        String           @id @default(cuid())
  title     String
  content   String?
  type      NotificationType
  createdAt DateTime         @default(now()) @map("created_at")

  targets NotificationTarget[]

  @@map("notification")
}

model NotificationTarget {
  notificationId String @map("notification_id")
  userId         String @map("user_id")

  isRead Boolean @default(false) @map("is_read")

  notification Notification @relation(fields: [notificationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@id([notificationId, userId])
  @@map("notification_target")
}

//////////////////////////////////////////////////
// PAYMENT
//////////////////////////////////////////////////

model Payment {
  id String @id @default(cuid())

  payerUserId String @map("payer_user_id")
  payer       User   @relation(fields: [payerUserId], references: [id])

  referenceType PaymentReferenceType @map("reference_type")
  referenceId   String               @map("reference_id")

  amount        Float
  status        PaymentStatus
  paymentMethod String?       @map("payment_method")

  orderCode     Int     @unique @default(autoincrement()) @map("order_code")
  checkoutUrl   String? @map("checkout_url")
  transactionId String? @map("transaction_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("payment")
}

model Report {
  id         String @id @default(cuid())
  reporterId String @map("reporter_id")

  targetType String       @map("target_type")
  targetId   Int          @map("target_id")
  reason     String?
  status     ReportStatus

  createdAt DateTime @default(now()) @map("created_at")

  reporter User @relation("Reporter", fields: [reporterId], references: [id])

  @@map("report")
}

//////////////////////////////////////////////////
// AI RECOMMENDATION SYSTEM (Managed by Python)
//////////////////////////////////////////////////

model Item {
  id              String                      @id
  itemType        String                      @map("itemType")
  basicInfo       Json                        @map("basicInfo")
  features        Json
  metrics         Json
  embeddingVector Unsupported("vector(384)")? @map("embeddingVector")
  createdAt       DateTime                    @default(now()) @map("createdAt")
  updatedAt       DateTime                    @updatedAt @map("updatedAt")

  @@index([itemType])
  @@map("items")
}

model Interaction {
  id        Int      @id @default(autoincrement())
  userId    String   @map("userId")
  itemId    String   @map("itemId")
  itemType  String   @map("itemType")
  type      String
  value     Float    @default(1.0)
  context   Json?
  createdAt DateTime @default(now()) @map("createdAt")

  @@index([userId])
  @@index([itemId])
  @@index([type])
  @@map("interactions")
}

//////////////////////////////////////////////////
// REVERSE MATCHING SYSTEM
//////////////////////////////////////////////////

model TutorRequest {
  id        String  @id @default(cuid())
  studentId String  @map("student_id")
  subjectId String? @map("subject_id")

  title       String
  description String
  mode        TutoringMode
  budget      Float?

  status RequestStatus @default(OPEN)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  student User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject Subject? @relation(fields: [subjectId], references: [id])

  bids          TutorBid[]
  scheduleRules ScheduleRule[]
  booking       Booking?

  sessions Session[]

  @@index([studentId])
  @@index([subjectId])
  @@index([status])
  @@map("tutor_request")
}

model TutorBid {
  id        String @id @default(cuid())
  requestId String @map("request_id")
  tutorId   String @map("tutor_id")

  proposedPrice Float?  @map("proposed_price")
  message       String?

  status BidStatus @default(PENDING)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  request TutorRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  tutor   Tutor        @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@unique([requestId, tutorId])
  @@index([requestId])
  @@index([tutorId])
  @@map("tutor_bid")
}

model UserAvailability {
  id        String @id @default(cuid())
  userId    String @map("user_id")

  dayOfWeek Int    @map("day_of_week")
  startTime String @map("start_time")
  endTime   String @map("end_time")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, dayOfWeek])
  @@map("user_availability")
}

model ScheduleRule {
  id        String  @id @default(cuid())
  bookingId String? @map("booking_id")
  requestId String? @map("request_id")

  dayOfWeek Int    @map("day_of_week")
  startTime String @map("start_time")
  endTime   String @map("end_time")

  booking Booking?      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  request TutorRequest? @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([requestId])
  @@map("schedule_rule")
}

model Session {
  id        String   @id @default(cuid())
  bookingId String?  @map("booking_id")
  title     String?
  startTime DateTime @map("start_time")
  endTime   DateTime @map("end_time")

  status     SessionStatus @default(SCHEDULED)
  meetingUrl String?       @map("meeting_url")
  notes      String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  attendances    SessionAttendance[]
  tutorRequest   TutorRequest?       @relation(fields: [tutorRequestId], references: [id])
  tutorRequestId String?

  @@index([bookingId])
  @@index([startTime])
  @@map("session")
}

model SessionAttendance {
  id        String @id @default(cuid())
  sessionId String @map("session_id")
  studentId String @map("student_id")

  status AttendanceStatus @default(PRESENT)
  notes  String?

  createdAt DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student User    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@map("session_attendance")
}

model Booking {
  id        String  @id @default(cuid())
  requestId String? @unique @map("request_id")
  studentId String  @map("student_id")
  tutorId   String  @map("tutor_id")
  subjectId String? @map("subject_id")

  startDate     DateTime? @map("start_date")
  totalSessions Int?      @map("total_sessions")

  mode   TutoringMode
  status BookingStatus @default(PENDING)

  meetingUrl String? @map("meeting_url")
  address    String? @map("address")

  price         Float?
  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  request       TutorRequest?  @relation(fields: [requestId], references: [id], onDelete: SetNull)
  student       User           @relation("StudentBookings", fields: [studentId], references: [id])
  tutor         Tutor          @relation(fields: [tutorId], references: [id])
  subject       Subject?       @relation(fields: [subjectId], references: [id])
  scheduleRules ScheduleRule[]

  sessions Session[]

  @@index([studentId])
  @@index([tutorId])
  @@map("booking")
}
