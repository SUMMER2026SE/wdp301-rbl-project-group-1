// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////

enum UserRole {
  ADMIN
  TUTOR
  STUDENT
  PARENT

  @@map("user_role")
}

enum Gender {
  MALE
  FEMALE
  OTHER

  @@map("gender")
}

enum OtpType {
  RESET_PASSWORD
  TWO_FACTOR
  VERIFY_EMAIL
}

enum CourseStatus {
  DRAFT
  PENDING_APPROVAL
  PUBLISHED
  ONGOING
  CLOSED
  REJECTED

  @@map("course_status")
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED

  @@map("enrollment_status")
}

enum LessonStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED

  @@map("lesson_status")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE

  @@map("attendance_status")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED

  @@map("payment_status")
}

enum PaymentReferenceType {
  COURSE_ENROLLMENT

  @@map("payment_reference_type")
}

enum NotificationType {
  SYSTEM
  COURSE
  FORUM

  @@map("notification_type")
}

enum ReportStatus {
  PENDING
  RESOLVED
  REJECTED

  @@map("report_status")
}

enum TutorApplicationStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("tutor_application_status")
}

enum CourseApplicationStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("course_application_status")
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED

  @@map("course_level")
}

enum TagCategory {
  KNOWLEDGE
  SKILL
  TOOL
}

enum ResourceType {
  FILE
  VIDEO
  LINK
  DOCUMENT

  @@map("resource_type")
}

enum InteractionEntityType {
  TUTOR
  COURSE
}

enum InteractionEventType {
  VIEW
  CLICK
  FAVORITE
  ENROLL
  SEARCH_CLICK
}

enum AssessmentType {
  QUIZ
  EXAM

  @@map("assessment_type")
}

enum QuestionType {
  MULTIPLE_CHOICE
  SINGLE_CHOICE
  TRUE_FALSE
  TEXT_ANSWER

  @@map("question_type")
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD

  @@map("question_difficulty")
}

enum GradingPolicy {
  HIGHEST
  AVERAGE
  LATEST

  @@map("grading_policy")
}

enum AuthProvider {
  LOCAL
  GOOGLE

  @@map("auth_provider")
}

//////////////////////////////////////////////////
// USER SYSTEM
//////////////////////////////////////////////////

model User {
  id       String   @id @default(cuid())
  email    String   @unique
  password String
  role     UserRole

  isActive    Boolean @default(true) @map("is_active")
  isVerified  Boolean @default(false) @map("is_verified")
  isFlag      Boolean @default(false) @map("is_flag")
  reportCount Int     @default(0) @map("report_count")

  createdAt DateTime @default(now()) @map("created_at")

  profile    Profile?
  identities UserIdentity[]

  refreshTokens RefreshToken[]

  tutor            Tutor?
  student          Student?
  parent           Parent?
  tutorApplication TutorApplication?

  posts                    Post[]
  comments                 Comment[]
  messages                 Message[]
  notifications            NotificationTarget[]
  reports                  Report[]                  @relation("Reporter")
  postLikes                PostLike[]
  conversationParticipants ConversationParticipant[]
  activityLogs             ActivityLog[]
  subjectInterests         UserSubjectInterest[]
  interactions             Interaction[]

  @@map("user")
}

model UserIdentity {
  id String @id @default(cuid())

  userId         String       @map("user_id")
  provider       AuthProvider
  providerUserId String       @map("provider_user_id")
  email          String?
  emailVerified  Boolean      @default(false) @map("email_verified")
  avatarUrl      String?      @map("avatar_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@index([provider, email])
  @@map("user_identity")
}

model Profile {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")

  nickname    String
  avatarUrl   String?  @map("avatar_url")
  phone       String   @map("phone")
  dateOfBirth DateTime @map("date_of_birth")
  gender      Gender?  @map("gender")
  address     String?  @map("address")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profile")
}

model UserSubjectInterest {
  userId    String @map("user_id")
  subjectId String @map("subject_id")

  weight Float @default(1)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([userId, subjectId])
  @@map("user_subject_interest")
}

model Tutor {
  id   String @id @map("id")
  user User   @relation(fields: [id], references: [id])

  bio            String?
  specialization String?
  experience     Int?
  education      String?
  pricePerHour   Float?  @map("price_per_hour")
  rating         Float   @default(0)
  reviewCount    Int     @default(0) @map("review_count")
  studentCount   Int     @default(0) @map("student_count")

  courses            Course[]
  stats              TutorStats?
  courseApplications CourseApplication[]

  @@map("tutor")
}

model TutorApplication {
  id String @id @default(cuid())

  email  String  @unique
  userId String? @unique @map("user_id")

  bio            String?
  specialization String
  experience     Int?
  education      String?
  pricePerHour   Float?   @map("price_per_hour")
  avatarUrl      String?  @map("avatar_url")
  files          String[] @default([])

  status TutorApplicationStatus @default(PENDING)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  subjects TutorApplicationSubject[]
  grades   TutorApplicationGrade[]

  @@index([status])
  @@index([createdAt])
  @@map("tutor_application")
}

model TutorApplicationSubject {
  tutorApplicationId String @map("tutor_application_id")
  subjectId          String @map("subject_id")

  tutorApplication TutorApplication @relation(fields: [tutorApplicationId], references: [id], onDelete: Cascade)
  subject          Subject          @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([tutorApplicationId, subjectId])
  @@map("tutor_application_subject")
}

model TutorApplicationGrade {
  tutorApplicationId String @map("tutor_application_id")
  gradeId            String @map("grade_id")

  tutorApplication TutorApplication @relation(fields: [tutorApplicationId], references: [id], onDelete: Cascade)
  grade            Grade            @relation(fields: [gradeId], references: [id], onDelete: Cascade)

  @@id([tutorApplicationId, gradeId])
  @@map("tutor_application_grade")
}

model CourseApplication {
  id       String @id @default(cuid())
  courseId String @unique @map("course_id")
  tutorId  String @map("tutor_id")

  status    CourseApplicationStatus @default(PENDING)
  adminNote String?                 @map("admin_note")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tutor  Tutor  @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
  @@map("course_application")
}

model Student {
  id   String @id
  user User   @relation(fields: [id], references: [id])

  grade        String?
  school       String?
  learningGoal String? @map("learning_goal")

  enrollments       Enrollment[]
  reviews           CourseReview[]
  lessonAttendances LessonAttendance[]
  attempts          Attempt[]
  gradebookRecords  GradebookRecord[]

  parents ParentStudent[]

  @@map("student")
}

model Parent {
  id   String @id
  user User   @relation(fields: [id], references: [id])

  phone   String?
  address String?

  children ParentStudent[]

  @@map("parent")
}

model ParentStudent {
  parentId  String @map("parent_id")
  studentId String @map("student_id")

  parent  Parent  @relation(fields: [parentId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@id([parentId, studentId])
  @@map("parent_student")
}

//////////////////////////////////////////////////
// AUTH
//////////////////////////////////////////////////

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  revoked   Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_token")
}

model Otp {
  id String @id @default(cuid())

  email  String
  userId String? @map("user_id") // optional nếu user đã tồn tại

  codeHash String  @map("code_hash") // hash OTP (không lưu plain text)
  type     OtpType

  expiresAt DateTime @map("expires_at")
  isUsed    Boolean  @default(false) @map("is_used")

  attempts    Int @default(0)
  maxAttempts Int @default(5) @map("max_attempts")

  lastSentAt DateTime? @map("last_sent_at")
  ipAddress  String?   @map("ip_address")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([email, type])
  @@index([userId])
  @@index([expiresAt])
  @@map("otp")
}

//////////////////////////////////////////////////
// MODEL
//////////////////////////////////////////////////

// ================= INTERACTION =================
model Interaction {
  id String @id @default(cuid())

  userId String @map("user_id")

  entityId   String                @map("entity_id")
  entityType InteractionEntityType @map("entity_type")

  eventType InteractionEventType @map("event_type")

  weight Float? // optional precomputed score

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityId, entityType])
  @@index([createdAt])
  @@map("interaction")
}

model UserTutorRecommendation {
  userId  String @map("user_id")
  tutorId String @map("tutor_id")

  score Float

  @@id([userId, tutorId])
  @@map("user_tutor_recommendation")
}

model UserCourseRecommendation {
  userId   String @map("user_id")
  courseId String @map("course_id")

  score Float

  @@id([userId, courseId])
  @@map("user_course_recommendation")
}

model TutorSimilarity {
  tutorId        String @map("tutor_id")
  similarTutorId String @map("similar_tutor_id")

  score Float

  @@id([tutorId, similarTutorId])
  @@map("tutor_similarity")
}

model CourseSimilarity {
  courseId        String @map("course_id")
  similarCourseId String @map("similar_course_id")

  score Float

  @@id([courseId, similarCourseId])
  @@map("course_similarity")
}

//////////////////////////////////////////////////
// COURSE SYSTEM
//////////////////////////////////////////////////

// ================= SUBJECT =================
model Subject {
  id String @id @default(cuid())

  name String // "Toán"
  slug String @unique // "toan"

  courses              Course[]
  userSubjectInterests UserSubjectInterest[]
  tutorApplications    TutorApplicationSubject[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("subject")
}

// ================= GRADE =================
model Grade {
  id String @id @default(cuid())

  name  String // "Lớp 11"
  slug  String @unique // "lop-11"
  order Int // để sort (10, 11, 12)

  courses           Course[]
  tutorApplications TutorApplicationGrade[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("grade")
}

// ================= TAG =================
model Tag {
  id String @id @default(cuid())

  name String // "Đạo hàm", "React"
  slug String @unique

  category TagCategory

  courses CourseTag[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("tag")
}

// ================= COURSE =================
model Course {
  id      String @id @default(cuid())
  tutorId String @map("tutor_id")

  title       String
  description String?
  price       Float?

  subjectId String @map("subject_id")
  gradeId   String @map("grade_id")

  level CourseLevel

  status    CourseStatus
  createdAt DateTime     @default(now()) @map("created_at")

  // RELATIONS
  tutor   Tutor   @relation(fields: [tutorId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  grade   Grade   @relation(fields: [gradeId], references: [id])

  tags CourseTag[]

  lessons          Lesson[]
  enrollments      Enrollment[]
  reviews          CourseReview[]
  stats            CourseStats?
  resources        CourseResource[]
  assessments      Assessment[]
  questionBanks    QuestionBank[]
  gradebookRecords GradebookRecord[]
  application      CourseApplication?

  // INDEX (quan trọng)
  @@index([subjectId])
  @@index([gradeId])
  @@index([level])
  @@map("course")
}

model CourseTag {
  courseId String @map("course_id")
  tagId    String @map("tag_id")

  course Course @relation(fields: [courseId], references: [id])
  tag    Tag    @relation(fields: [tagId], references: [id])

  @@id([courseId, tagId])
  @@map("course_tag")
}

model Lesson {
  id       String @id @default(cuid())
  courseId String @map("course_id")

  title      String
  content    String?
  meetingUrl String?      @map("meeting_url")
  videoUrl   String?      @map("video_url")
  startTime  DateTime     @map("start_time")
  endTime    DateTime     @map("end_time")
  orderIndex Int          @map("order_index")
  status     LessonStatus @default(SCHEDULED)
  createdAt  DateTime     @default(now()) @map("created_at")

  course      Course             @relation(fields: [courseId], references: [id])
  attendances LessonAttendance[]
  resources   LessonResource[]
  assessments Assessment[]

  @@map("lesson")
}

model LessonAttendance {
  id String @id @default(cuid())

  studentId String @map("student_id")

  status AttendanceStatus @map("attendance_status")
  note   String?

  markedAt  DateTime @default(now()) @map("marked_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lessonId String? @map("lesson_id")
  lesson   Lesson? @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student  Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([lessonId, studentId])
  @@index([studentId])
  @@index([status])
  @@map("lesson_attendance")
}

model Enrollment {
  id        String @id @default(cuid())
  studentId String @map("student_id")
  courseId  String @map("course_id")

  status     EnrollmentStatus
  enrolledAt DateTime         @default(now()) @map("enrolled_at")

  student Student @relation(fields: [studentId], references: [id])
  course  Course  @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId])
  @@map("enrollment")
}

model CourseReview {
  id        String @id @default(cuid())
  courseId  String @map("course_id")
  studentId String @map("student_id")

  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  course  Course  @relation(fields: [courseId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@map("course_review")
}

//////////////////////////////////////////////////
// RESOURCE SYSTEM
//////////////////////////////////////////////////

model Resource {
  id   String       @id @default(cuid())
  name String
  url  String
  type ResourceType
  size Int? // Size in bytes

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  courseResources CourseResource[]
  lessonResources LessonResource[]

  @@map("resource")
}

model CourseResource {
  courseId   String @map("course_id")
  resourceId String @map("resource_id")

  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@id([courseId, resourceId])
  @@map("course_resource")
}

model LessonResource {
  lessonId   String @map("lesson_id")
  resourceId String @map("resource_id")

  lesson   Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@id([lessonId, resourceId])
  @@map("lesson_resource")
}

//////////////////////////////////////////////////
// ASSESSMENT SYSTEM
//////////////////////////////////////////////////

model Assessment {
  id       String  @id @default(cuid())
  courseId String  @map("course_id")
  lessonId String? @map("lesson_id")

  title       String
  description String?
  type        AssessmentType

  maxAttempts    Int?          @map("max_attempts")
  timeLimit      Int?          @map("time_limit") // minutes
  isRandomized   Boolean       @default(false) @map("is_randomized")
  shuffleOptions Boolean       @default(false) @map("shuffle_options")
  antiCheat      Boolean       @default(false) @map("anti_cheat")
  passScore      Float?        @map("pass_score")
  gradingPolicy  GradingPolicy @default(HIGHEST) @map("grading_policy")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  course Course  @relation(fields: [courseId], references: [id])
  lesson Lesson? @relation(fields: [lessonId], references: [id])

  questions        Question[]
  attempts         Attempt[]
  bankConfigs      AssessmentBankConfig[]
  gradebookRecords GradebookRecord[]

  @@map("assessment")
}

model Question {
  id           String  @id @default(cuid())
  assessmentId String? @map("assessment_id")
  bankId       String? @map("bank_id")

  type       QuestionType
  difficulty QuestionDifficulty @default(MEDIUM)
  content    String
  points     Float              @default(1)
  orderIndex Int                @map("order_index")

  assessment Assessment?   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  bank       QuestionBank? @relation(fields: [bankId], references: [id], onDelete: Cascade)

  options        Option[]
  attemptAnswers AttemptAnswer[]

  @@map("question")
}

model Option {
  id         String @id @default(cuid())
  questionId String @map("question_id")

  content    String
  isCorrect  Boolean @default(false) @map("is_correct")
  orderIndex Int     @map("order_index")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("option")
}

model Attempt {
  id           String @id @default(cuid())
  assessmentId String @map("assessment_id")
  studentId    String @map("student_id")

  startTime DateTime  @default(now()) @map("start_time")
  endTime   DateTime? @map("end_time")

  score    Float?
  isPassed Boolean? @map("is_passed")

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  answers         AttemptAnswer[]
  gradebookRecord GradebookRecord? @relation("BestAttempt")

  @@map("attempt")
}

model AttemptAnswer {
  id         String @id @default(cuid())
  attemptId  String @map("attempt_id")
  questionId String @map("question_id")

  optionIds  String[] @map("option_ids") // For Multiple/Single choice
  textAnswer String?  @map("text_answer") // For Text Answer

  isCorrect Boolean? @map("is_correct")
  points    Float?

  attempt  Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])

  @@map("attempt_answer")
}

model QuestionBank {
  id          String  @id @default(cuid())
  courseId    String  @map("course_id")
  title       String
  description String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  course            Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions         Question[]
  assessmentConfigs AssessmentBankConfig[]

  @@map("question_bank")
}

model AssessmentBankConfig {
  id           String @id @default(cuid())
  assessmentId String @map("assessment_id")
  bankId       String @map("bank_id")

  difficulty        QuestionDifficulty?
  count             Int
  pointsPerQuestion Float               @default(1) @map("points_per_question")

  assessment Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  bank       QuestionBank @relation(fields: [bankId], references: [id], onDelete: Cascade)

  @@map("assessment_bank_config")
}

model GradebookRecord {
  id           String @id @default(cuid())
  studentId    String @map("student_id")
  courseId     String @map("course_id")
  assessmentId String @map("assessment_id")

  finalScore Float   @map("final_score")
  isPassed   Boolean @map("is_passed")

  bestAttemptId String? @unique @map("best_attempt_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  student     Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course      Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  assessment  Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  bestAttempt Attempt?   @relation("BestAttempt", fields: [bestAttemptId], references: [id])

  @@unique([studentId, assessmentId])
  @@map("gradebook_record")
}

//////////////////////////////////////////////////
// FORUM
//////////////////////////////////////////////////

model Post {
  id     String @id @default(cuid())
  userId String @map("user_id")

  title     String
  content   String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @map("updated_at")

  user       User           @relation(fields: [userId], references: [id])
  comments   Comment[]
  likes      PostLike[]
  categories PostCategory[]

  @@map("post")
}

model Comment {
  id     String @id @default(cuid())
  postId String @map("post_id")
  userId String @map("user_id")

  content   String
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@map("comment")
}

model PostLike {
  userId String @map("user_id")
  postId String @map("post_id")

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])

  @@id([userId, postId])
  @@map("post_like")
}

model Category {
  id   String @id @default(cuid())
  name String

  posts PostCategory[]

  @@map("category")
}

model PostCategory {
  postId     String @map("post_id")
  categoryId String @map("category_id")

  post     Post     @relation(fields: [postId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@id([postId, categoryId])
  @@map("post_category")
}

//////////////////////////////////////////////////
// NOTIFICATION
//////////////////////////////////////////////////

model Notification {
  id        String           @id @default(cuid())
  title     String
  content   String?
  type      NotificationType
  createdAt DateTime         @default(now()) @map("created_at")

  targets NotificationTarget[]

  @@map("notification")
}

model NotificationTarget {
  notificationId String @map("notification_id")
  userId         String @map("user_id")

  isRead Boolean @default(false) @map("is_read")

  notification Notification @relation(fields: [notificationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@id([notificationId, userId])
  @@map("notification_target")
}

//////////////////////////////////////////////////
// PAYMENT
//////////////////////////////////////////////////

model Payment {
  id        String @id @default(cuid())
  
  payerUserId String @map("payer_user_id")

  referenceType PaymentReferenceType @map("reference_type")
  referenceId   String               @map("reference_id")

  amount        Float
  status        PaymentStatus
  paymentMethod String?       @map("payment_method")

  orderCode     Int     @unique @default(autoincrement()) @map("order_code")
  checkoutUrl   String? @map("checkout_url")
  transactionId String? @map("transaction_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("payment")
}

//////////////////////////////////////////////////
// CHAT
//////////////////////////////////////////////////

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversation")
}

model ConversationParticipant {
  conversationId String @map("conversation_id")
  userId         String @map("user_id")

  conversation Conversation @relation(fields: [conversationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@id([conversationId, userId])
  @@map("conversation_participant")
}

model Message {
  id             String @id @default(cuid())
  conversationId String @map("conversation_id")
  senderId       String @map("sender_id")

  content   String
  createdAt DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation(fields: [senderId], references: [id])

  @@map("message")
}

//////////////////////////////////////////////////
// ANALYTICS
//////////////////////////////////////////////////

model SystemStats {
  id   String   @id @default(cuid())
  date DateTime @unique

  totalUsers         Int   @map("total_users")
  totalTutors        Int   @map("total_tutors")
  totalStudents      Int   @map("total_students")
  totalCourses       Int   @map("total_courses")
  totalActiveCourses Int   @map("total_active_courses")
  totalEnrollments   Int   @map("total_enrollments")
  totalRevenue       Float @map("total_revenue")
  totalPosts         Int   @map("total_posts")
  totalComments      Int   @map("total_comments")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("system_stats")
}

model TutorStats {
  tutorId String @id @map("tutor_id")

  totalStudents Int   @map("total_students")
  totalCourses  Int   @map("total_courses")
  totalEarnings Float @map("total_earnings")
  avgRating     Float @map("avg_rating")

  tutor Tutor @relation(fields: [tutorId], references: [id])

  @@map("tutor_stats")
}

model CourseStats {
  courseId String @id @map("course_id")

  totalStudents Int   @map("total_students")
  totalRevenue  Float @map("total_revenue")
  avgRating     Float @map("avg_rating")

  course Course @relation(fields: [courseId], references: [id])

  @@map("course_stats")
}

model ActivityLog {
  id     String @id @default(cuid())
  userId String @map("user_id")

  action     String
  entityType String @map("entity_type")
  entityId   Int    @map("entity_id")

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("activity_log")
}

model Report {
  id         String @id @default(cuid())
  reporterId String @map("reporter_id")

  targetType String       @map("target_type")
  targetId   Int          @map("target_id")
  reason     String?
  status     ReportStatus

  createdAt DateTime @default(now()) @map("created_at")

  reporter User @relation("Reporter", fields: [reporterId], references: [id])

  @@map("report")
}
