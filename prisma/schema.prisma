// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////

enum UserRole {
  ADMIN
  TUTOR
  STUDENT
  PARENT

  @@map("user_role")
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ONGOING
  CLOSED

  @@map("course_status")
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED

  @@map("enrollment_status")
}

enum ScheduleStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED

  @@map("schedule_status")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE

  @@map("attendance_status")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED

  @@map("payment_status")
}

enum NotificationType {
  SYSTEM
  COURSE
  FORUM

  @@map("notification_type")
}

enum ReportStatus {
  PENDING
  RESOLVED
  REJECTED

  @@map("report_status")
}

//////////////////////////////////////////////////
// USER SYSTEM
//////////////////////////////////////////////////

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  password String
  role     UserRole
  nickname String

  isActive    Boolean @default(true) @map("is_active")
  isVerified  Boolean @default(false) @map("is_verified")
  isFlag      Boolean @default(false) @map("is_flag")
  reportCount Int     @default(0) @map("report_count")

  createdAt DateTime @default(now()) @map("created_at")

  refreshTokens RefreshToken[]

  tutor   Tutor?
  student Student?
  parent  Parent?

  posts                    Post[]
  comments                 Comment[]
  messages                 Message[]
  notifications            NotificationTarget[]
  reports                  Report[]                  @relation("Reporter")
  postLikes                PostLike[]
  conversationParticipants ConversationParticipant[]
  activityLogs             ActivityLog[]

  @@map("user")
}

model Tutor {
  id   Int  @id @map("id")
  user User @relation(fields: [id], references: [id])

  bio            String?
  specialization String?
  experience     Int?
  education      String?
  pricePerHour   Float?  @map("price_per_hour")
  rating         Float   @default(0)
  reviewCount    Int     @default(0) @map("review_count")
  studentCount   Int     @default(0) @map("student_count")

  courses Course[]
  stats   TutorStats?

  @@map("tutor")
}

model Student {
  id   Int  @id
  user User @relation(fields: [id], references: [id])

  grade        String?
  school       String?
  learningGoal String? @map("learning_goal")

  enrollments Enrollment[]
  reviews     CourseReview[]
  schedules   ScheduleStudent[]
  payments    Payment[]

  parents ParentStudent[]

  @@map("student")
}

model Parent {
  id   Int  @id
  user User @relation(fields: [id], references: [id])

  phone   String?
  address String?

  children ParentStudent[]

  @@map("parent")
}

model ParentStudent {
  parentId  Int @map("parent_id")
  studentId Int @map("student_id")

  parent  Parent  @relation(fields: [parentId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@id([parentId, studentId])
  @@map("parent_student")
}

//////////////////////////////////////////////////
// AUTH
//////////////////////////////////////////////////

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  revoked   Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_token")
}

//////////////////////////////////////////////////
// COURSE SYSTEM
//////////////////////////////////////////////////

model Course {
  id      Int @id @default(autoincrement())
  tutorId Int @map("tutor_id")

  title       String
  description String?
  price       Float?
  level       String?

  status    CourseStatus
  createdAt DateTime     @default(now()) @map("created_at")

  tutor Tutor @relation(fields: [tutorId], references: [id])

  lessons     Lesson[]
  enrollments Enrollment[]
  reviews     CourseReview[]
  schedules   Schedule[]
  payments    Payment[]
  stats       CourseStats?

  @@map("course")
}

model Lesson {
  id       Int @id @default(autoincrement())
  courseId Int @map("course_id")

  title      String
  content    String?
  videoUrl   String? @map("video_url")
  orderIndex Int     @map("order_index")

  course Course @relation(fields: [courseId], references: [id])

  @@map("lesson")
}

model Enrollment {
  id        Int @id @default(autoincrement())
  studentId Int @map("student_id")
  courseId  Int @map("course_id")

  status     EnrollmentStatus
  enrolledAt DateTime         @default(now()) @map("enrolled_at")

  student Student @relation(fields: [studentId], references: [id])
  course  Course  @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId])
  @@map("enrollment")
}

model CourseReview {
  id        Int @id @default(autoincrement())
  courseId  Int @map("course_id")
  studentId Int @map("student_id")

  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  course  Course  @relation(fields: [courseId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@map("course_review")
}

//////////////////////////////////////////////////
// SCHEDULE
//////////////////////////////////////////////////

model Schedule {
  id       Int @id @default(autoincrement())
  courseId Int @map("course_id")

  title      String
  startTime  DateTime @map("start_time")
  endTime    DateTime @map("end_time")
  meetingUrl String?  @map("meeting_url")

  status    ScheduleStatus
  createdAt DateTime       @default(now()) @map("created_at")

  course   Course            @relation(fields: [courseId], references: [id])
  students ScheduleStudent[]

  @@map("schedule")
}

model ScheduleStudent {
  scheduleId Int @map("schedule_id")
  studentId  Int @map("student_id")

  attendanceStatus AttendanceStatus @map("attendance_status")

  schedule Schedule @relation(fields: [scheduleId], references: [id])
  student  Student  @relation(fields: [studentId], references: [id])

  @@id([scheduleId, studentId])
  @@map("schedule_student")
}

//////////////////////////////////////////////////
// FORUM
//////////////////////////////////////////////////

model Post {
  id     Int @id @default(autoincrement())
  userId Int @map("user_id")

  title     String
  content   String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @map("updated_at")

  user       User           @relation(fields: [userId], references: [id])
  comments   Comment[]
  likes      PostLike[]
  categories PostCategory[]

  @@map("post")
}

model Comment {
  id     Int @id @default(autoincrement())
  postId Int @map("post_id")
  userId Int @map("user_id")

  content   String
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@map("comment")
}

model PostLike {
  userId Int @map("user_id")
  postId Int @map("post_id")

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])

  @@id([userId, postId])
  @@map("post_like")
}

model Category {
  id   Int    @id @default(autoincrement())
  name String

  posts PostCategory[]

  @@map("category")
}

model PostCategory {
  postId     Int @map("post_id")
  categoryId Int @map("category_id")

  post     Post     @relation(fields: [postId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@id([postId, categoryId])
  @@map("post_category")
}

//////////////////////////////////////////////////
// NOTIFICATION
//////////////////////////////////////////////////

model Notification {
  id        Int              @id @default(autoincrement())
  title     String
  content   String?
  type      NotificationType
  createdAt DateTime         @default(now()) @map("created_at")

  targets NotificationTarget[]

  @@map("notification")
}

model NotificationTarget {
  notificationId Int @map("notification_id")
  userId         Int @map("user_id")

  isRead Boolean @default(false) @map("is_read")

  notification Notification @relation(fields: [notificationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@id([notificationId, userId])
  @@map("notification_target")
}

//////////////////////////////////////////////////
// PAYMENT
//////////////////////////////////////////////////

model Payment {
  id        Int @id @default(autoincrement())
  studentId Int @map("student_id")
  courseId  Int @map("course_id")

  amount        Float
  status        PaymentStatus
  paymentMethod String?       @map("payment_method")

  createdAt DateTime @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id])
  course  Course  @relation(fields: [courseId], references: [id])

  @@map("payment")
}

//////////////////////////////////////////////////
// CHAT
//////////////////////////////////////////////////

model Conversation {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")

  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversation")
}

model ConversationParticipant {
  conversationId Int @map("conversation_id")
  userId         Int @map("user_id")

  conversation Conversation @relation(fields: [conversationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@id([conversationId, userId])
  @@map("conversation_participant")
}

model Message {
  id             Int @id @default(autoincrement())
  conversationId Int @map("conversation_id")
  senderId       Int @map("sender_id")

  content   String
  createdAt DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation(fields: [senderId], references: [id])

  @@map("message")
}

//////////////////////////////////////////////////
// ANALYTICS
//////////////////////////////////////////////////

model SystemStats {
  id   Int      @id @default(autoincrement())
  date DateTime @unique

  totalUsers         Int   @map("total_users")
  totalTutors        Int   @map("total_tutors")
  totalStudents      Int   @map("total_students")
  totalCourses       Int   @map("total_courses")
  totalActiveCourses Int   @map("total_active_courses")
  totalEnrollments   Int   @map("total_enrollments")
  totalRevenue       Float @map("total_revenue")
  totalPosts         Int   @map("total_posts")
  totalComments      Int   @map("total_comments")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("system_stats")
}

model TutorStats {
  tutorId Int @id @map("tutor_id")

  totalStudents Int   @map("total_students")
  totalCourses  Int   @map("total_courses")
  totalEarnings Float @map("total_earnings")
  avgRating     Float @map("avg_rating")

  tutor Tutor @relation(fields: [tutorId], references: [id])

  @@map("tutor_stats")
}

model CourseStats {
  courseId Int @id @map("course_id")

  totalStudents Int   @map("total_students")
  totalRevenue  Float @map("total_revenue")
  avgRating     Float @map("avg_rating")

  course Course @relation(fields: [courseId], references: [id])

  @@map("course_stats")
}

model ActivityLog {
  id     Int @id @default(autoincrement())
  userId Int @map("user_id")

  action     String
  entityType String @map("entity_type")
  entityId   Int    @map("entity_id")

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("activity_log")
}

model Report {
  id         Int @id @default(autoincrement())
  reporterId Int @map("reporter_id")

  targetType String       @map("target_type")
  targetId   Int          @map("target_id")
  reason     String?
  status     ReportStatus

  createdAt DateTime @default(now()) @map("created_at")

  reporter User @relation("Reporter", fields: [reporterId], references: [id])

  @@map("report")
}
